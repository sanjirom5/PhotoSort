# --- Google Drive ---
# Path to your service account JSON key file.
# Go to: console.cloud.google.com → IAM → Service Accounts → Create key (JSON)
# Enable "Google Drive API" in the project.
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json

# --- Telegram Bot ---
# Get from @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxx

# Bot username WITHOUT the @, e.g. photosortbot
BOT_USERNAME=photosortbot

# --- LLM (optional — enables rename clusters, smart search, album titles) ---
# Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx
